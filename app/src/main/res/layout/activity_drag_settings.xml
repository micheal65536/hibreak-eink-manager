<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
			  xmlns:app="http://schemas.android.com/apk/res-auto"
			  android:layout_width="match_parent"
			  android:layout_height="match_parent"
			  android:orientation="vertical">
	<com.google.android.material.appbar.MaterialToolbar android:id="@+id/toolbar"
														style="@style/Widget.MaterialComponents.Toolbar.Primary"
														android:layout_width="match_parent"
														android:layout_height="wrap_content" />
	<androidx.core.widget.NestedScrollView android:layout_width="match_parent"
										   android:layout_height="match_parent"
										   android:scrollbars="vertical">
		<androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent"
														   android:layout_height="match_parent">
			<LinearLayout android:id="@+id/drag_start_delay_static"
						  android:layout_width="match_parent"
						  android:layout_height="wrap_content"
						  android:layout_marginHorizontal="16dp"
						  android:layout_marginTop="14dp"
						  android:orientation="horizontal"
						  app:layout_constraintTop_toTopOf="parent">
				<TextView android:layout_width="0dp"
						  android:layout_height="wrap_content"
						  android:layout_gravity="center_vertical"
						  android:layout_marginEnd="12dp"
						  android:layout_weight="1"
						  android:text="@string/drag_start_delay_static"
						  android:textColor="?attr/colorOnSurface" />
				<include android:id="@+id/drag_start_delay_static_value"
						 layout="@layout/numeric_input_4_digits"
						 android:layout_width="wrap_content"
						 android:layout_height="wrap_content"
						 android:layout_marginVertical="2dp" />
			</LinearLayout>
			<LinearLayout android:id="@+id/drag_start_delay_moving"
						  android:layout_width="match_parent"
						  android:layout_height="wrap_content"
						  android:layout_marginHorizontal="16dp"
						  android:orientation="horizontal"
						  app:layout_constraintTop_toBottomOf="@id/drag_start_delay_static">
				<TextView android:layout_width="0dp"
						  android:layout_height="wrap_content"
						  android:layout_gravity="center_vertical"
						  android:layout_marginEnd="12dp"
						  android:layout_weight="1"
						  android:text="@string/drag_start_delay_moving"
						  android:textColor="?attr/colorOnSurface" />
				<include android:id="@+id/drag_start_delay_moving_value"
						 layout="@layout/numeric_input_4_digits"
						 android:layout_width="wrap_content"
						 android:layout_height="wrap_content"
						 android:layout_marginVertical="2dp" />
			</LinearLayout>
			<LinearLayout android:id="@+id/drag_start_distance"
						  android:layout_width="match_parent"
						  android:layout_height="wrap_content"
						  android:layout_marginHorizontal="16dp"
						  android:orientation="horizontal"
						  app:layout_constraintTop_toBottomOf="@id/drag_start_delay_moving">
				<TextView android:layout_width="0dp"
						  android:layout_height="wrap_content"
						  android:layout_gravity="center_vertical"
						  android:layout_marginEnd="12dp"
						  android:layout_weight="1"
						  android:text="@string/drag_start_distance"
						  android:textColor="?attr/colorOnSurface" />
				<include android:id="@+id/drag_start_distance_value"
						 layout="@layout/numeric_input_3_digits"
						 android:layout_width="wrap_content"
						 android:layout_height="wrap_content"
						 android:layout_marginVertical="2dp" />
			</LinearLayout>
			<LinearLayout android:id="@+id/drag_end_delay"
						  android:layout_width="match_parent"
						  android:layout_height="wrap_content"
						  android:layout_marginHorizontal="16dp"
						  android:orientation="horizontal"
						  app:layout_constraintTop_toBottomOf="@id/drag_start_distance">
				<TextView android:layout_width="0dp"
						  android:layout_height="wrap_content"
						  android:layout_gravity="center_vertical"
						  android:layout_marginEnd="12dp"
						  android:layout_weight="1"
						  android:text="@string/drag_end_delay"
						  android:textColor="?attr/colorOnSurface" />
				<include android:id="@+id/drag_end_delay_value"
						 layout="@layout/numeric_input_4_digits"
						 android:layout_width="wrap_content"
						 android:layout_height="wrap_content"
						 android:layout_marginVertical="2dp" />
			</LinearLayout>
			<Space android:layout_width="match_parent"
				   android:layout_height="14dp"
				   app:layout_constraintBottom_toBottomOf="parent"
				   app:layout_constraintTop_toBottomOf="@id/drag_end_delay" />
		</androidx.constraintlayout.widget.ConstraintLayout>
	</androidx.core.widget.NestedScrollView>
</LinearLayout>