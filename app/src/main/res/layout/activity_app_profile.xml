<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
			  xmlns:app="http://schemas.android.com/apk/res-auto"
			  xmlns:tools="http://schemas.android.com/tools"
			  android:layout_width="match_parent"
			  android:layout_height="match_parent"
			  android:orientation="vertical">
	<com.google.android.material.appbar.MaterialToolbar android:id="@+id/toolbar"
														style="@style/Widget.MaterialComponents.Toolbar.Primary"
														android:layout_width="match_parent"
														android:layout_height="wrap_content"
														app:menu="@menu/app_profile"
														tools:title="com.example.test">
		<com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/enabled"
																   android:layout_width="wrap_content"
																   android:layout_height="wrap_content"
																   android:layout_gravity="end"
																   android:layout_marginHorizontal="4dp"
																   android:contentDescription="@string/enabled"
																   app:materialThemeOverlay="@style/ThemeOverlay.EInkManager.OnPrimary"
																   tools:checked="true" />
	</com.google.android.material.appbar.MaterialToolbar>
	<androidx.core.widget.NestedScrollView android:layout_width="match_parent"
										   android:layout_height="match_parent"
										   android:scrollbars="vertical">
		<androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent"
														   android:layout_height="match_parent">
			<com.google.android.material.button.MaterialButtonGroup android:id="@+id/refresh_mode"
																	android:layout_width="wrap_content"
																	android:layout_height="wrap_content"
																	android:layout_marginTop="16dp"
																	android:spacing="0dp"
																	app:buttonSizeChange="@null"
																	app:innerCornerSize="0dp"
																	app:layout_constraintEnd_toEndOf="parent"
																	app:layout_constraintStart_toStartOf="parent"
																	app:layout_constraintTop_toTopOf="parent">
				<com.google.android.material.button.MaterialButton android:id="@+id/refresh_mode_default"
																   style="@style/Widget.MaterialComponents.Button.OutlinedButton"
																   android:layout_width="wrap_content"
																   android:layout_height="wrap_content"
																   android:checkable="true"
																   android:minWidth="48dp"
																   android:text="@string/profile_setting_default" />
				<com.google.android.material.button.MaterialButton android:id="@+id/refresh_mode_normal"
																   style="@style/Widget.MaterialComponents.Button.OutlinedButton"
																   android:layout_width="wrap_content"
																   android:layout_height="wrap_content"
																   android:checkable="true"
																   android:minWidth="48dp"
																   android:text="@string/refresh_mode_normal" />
				<com.google.android.material.button.MaterialButton android:id="@+id/refresh_mode_fast"
																   style="@style/Widget.MaterialComponents.Button.OutlinedButton"
																   android:layout_width="wrap_content"
																   android:layout_height="wrap_content"
																   android:checkable="true"
																   android:minWidth="48dp"
																   android:text="@string/refresh_mode_fast" />
				<com.google.android.material.button.MaterialButton android:id="@+id/refresh_mode_high_quality"
																   style="@style/Widget.MaterialComponents.Button.OutlinedButton"
																   android:layout_width="wrap_content"
																   android:layout_height="wrap_content"
																   android:layout_marginTop="16dp"
																   android:checkable="true"
																   android:minWidth="48dp"
																   android:text="@string/refresh_mode_high_quality" />
			</com.google.android.material.button.MaterialButtonGroup>
			<LinearLayout android:id="@+id/enable_drag_mode_switch"
						  android:layout_width="match_parent"
						  android:layout_height="wrap_content"
						  android:layout_marginHorizontal="16dp"
						  android:orientation="horizontal"
						  app:layout_constraintTop_toBottomOf="@id/refresh_mode">
				<TextView android:layout_width="0dp"
						  android:layout_height="wrap_content"
						  android:layout_gravity="center_vertical"
						  android:layout_marginEnd="12dp"
						  android:layout_weight="1"
						  android:text="@string/enable_drag_mode_switch"
						  android:textColor="?attr/colorOnSurface" />
				<com.google.android.material.button.MaterialButtonGroup android:layout_width="wrap_content"
																		android:layout_height="wrap_content"
																		android:layout_gravity="center_vertical"
																		android:spacing="0dp"
																		app:buttonSizeChange="@null"
																		app:innerCornerSize="0dp">
					<com.google.android.material.button.MaterialButton android:id="@+id/enable_drag_mode_switch_default"
																	   style="@style/Widget.MaterialComponents.Button.OutlinedButton"
																	   android:layout_width="wrap_content"
																	   android:layout_height="wrap_content"
																	   android:checkable="true"
																	   android:minWidth="48dp"
																	   android:text="@string/profile_setting_default" />
					<com.google.android.material.button.MaterialButton android:id="@+id/enable_drag_mode_switch_on"
																	   style="@style/Widget.MaterialComponents.Button.OutlinedButton"
																	   android:layout_width="wrap_content"
																	   android:layout_height="wrap_content"
																	   android:checkable="true"
																	   android:minWidth="48dp"
																	   android:text="@string/profile_setting_on" />
					<com.google.android.material.button.MaterialButton android:id="@+id/enable_drag_mode_switch_off"
																	   style="@style/Widget.MaterialComponents.Button.OutlinedButton"
																	   android:layout_width="wrap_content"
																	   android:layout_height="wrap_content"
																	   android:checkable="true"
																	   android:minWidth="48dp"
																	   android:text="@string/profile_setting_off" />
				</com.google.android.material.button.MaterialButtonGroup>
			</LinearLayout>
			<LinearLayout android:id="@+id/enable_ime_mode_switch"
						  android:layout_width="match_parent"
						  android:layout_height="wrap_content"
						  android:layout_marginHorizontal="16dp"
						  android:orientation="horizontal"
						  app:layout_constraintTop_toBottomOf="@id/enable_drag_mode_switch">
				<TextView android:layout_width="0dp"
						  android:layout_height="wrap_content"
						  android:layout_gravity="center_vertical"
						  android:layout_marginEnd="12dp"
						  android:layout_weight="1"
						  android:text="@string/enable_ime_mode_switch"
						  android:textColor="?attr/colorOnSurface" />
				<com.google.android.material.button.MaterialButtonGroup android:layout_width="wrap_content"
																		android:layout_height="wrap_content"
																		android:layout_gravity="center_vertical"
																		android:spacing="0dp"
																		app:buttonSizeChange="@null"
																		app:innerCornerSize="0dp">
					<com.google.android.material.button.MaterialButton android:id="@+id/enable_ime_mode_switch_default"
																	   style="@style/Widget.MaterialComponents.Button.OutlinedButton"
																	   android:layout_width="wrap_content"
																	   android:layout_height="wrap_content"
																	   android:checkable="true"
																	   android:minWidth="48dp"
																	   android:text="@string/profile_setting_default" />
					<com.google.android.material.button.MaterialButton android:id="@+id/enable_ime_mode_switch_on"
																	   style="@style/Widget.MaterialComponents.Button.OutlinedButton"
																	   android:layout_width="wrap_content"
																	   android:layout_height="wrap_content"
																	   android:checkable="true"
																	   android:minWidth="48dp"
																	   android:text="@string/profile_setting_on" />
					<com.google.android.material.button.MaterialButton android:id="@+id/enable_ime_mode_switch_off"
																	   style="@style/Widget.MaterialComponents.Button.OutlinedButton"
																	   android:layout_width="wrap_content"
																	   android:layout_height="wrap_content"
																	   android:checkable="true"
																	   android:minWidth="48dp"
																	   android:text="@string/profile_setting_off" />
				</com.google.android.material.button.MaterialButtonGroup>
			</LinearLayout>

			<com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/disable_global_contrast_map"
																	   android:layout_width="match_parent"
																	   android:layout_height="wrap_content"
																	   android:layout_marginHorizontal="16dp"
																	   android:layout_marginTop="16dp"
																	   android:text="@string/disable_global_contrast_map"
																	   app:layout_constraintTop_toBottomOf="@id/enable_ime_mode_switch" />
			<com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/use_color_map"
																	   android:layout_width="match_parent"
																	   android:layout_height="wrap_content"
																	   android:layout_marginHorizontal="16dp"
																	   android:text="@string/use_color_map"
																	   app:layout_constraintTop_toBottomOf="@id/disable_global_contrast_map" />
			<TextView android:id="@+id/color_map_red_label"
					  android:layout_width="wrap_content"
					  android:layout_height="wrap_content"
					  android:layout_marginStart="16dp"
					  android:text="@string/color_map_red"
					  android:textColor="?attr/colorOnSurface"
					  app:layout_constraintBottom_toBottomOf="@id/color_map_red_min"
					  app:layout_constraintStart_toStartOf="parent"
					  app:layout_constraintTop_toTopOf="@id/color_map_red_min" />
			<TextView android:id="@+id/color_map_green_label"
					  android:layout_width="wrap_content"
					  android:layout_height="wrap_content"
					  android:layout_marginStart="16dp"
					  android:text="@string/color_map_green"
					  android:textColor="?attr/colorOnSurface"
					  app:layout_constraintBottom_toBottomOf="@id/color_map_green_min"
					  app:layout_constraintStart_toStartOf="parent"
					  app:layout_constraintTop_toTopOf="@id/color_map_green_min" />
			<TextView android:id="@+id/color_map_blue_label"
					  android:layout_width="wrap_content"
					  android:layout_height="wrap_content"
					  android:layout_marginStart="16dp"
					  android:text="@string/color_map_blue"
					  android:textColor="?attr/colorOnSurface"
					  app:layout_constraintBottom_toBottomOf="@id/color_map_blue_min"
					  app:layout_constraintStart_toStartOf="parent"
					  app:layout_constraintTop_toTopOf="@id/color_map_blue_min" />
			<androidx.constraintlayout.widget.Barrier android:id="@+id/color_map_labels_barrier"
													  android:layout_width="wrap_content"
													  android:layout_height="match_parent"
													  app:barrierDirection="end"
													  app:constraint_referenced_ids="color_map_red_label,color_map_green_label,color_map_blue_label" />
			<include android:id="@+id/color_map_red_min"
					 layout="@layout/numeric_input_3_digits"
					 android:layout_width="wrap_content"
					 android:layout_height="wrap_content"
					 app:layout_constraintEnd_toStartOf="@id/color_map_red_max"
					 app:layout_constraintStart_toEndOf="@id/color_map_labels_barrier"
					 app:layout_constraintTop_toBottomOf="@id/use_color_map" />
			<include android:id="@+id/color_map_red_max"
					 layout="@layout/numeric_input_3_digits"
					 android:layout_width="wrap_content"
					 android:layout_height="wrap_content"
					 android:layout_marginEnd="16dp"
					 app:layout_constraintEnd_toEndOf="parent"
					 app:layout_constraintTop_toBottomOf="@id/use_color_map" />
			<include android:id="@+id/color_map_green_min"
					 layout="@layout/numeric_input_3_digits"
					 android:layout_width="wrap_content"
					 android:layout_height="wrap_content"
					 android:layout_marginTop="4dp"
					 app:layout_constraintEnd_toStartOf="@id/color_map_green_max"
					 app:layout_constraintStart_toEndOf="@id/color_map_labels_barrier"
					 app:layout_constraintTop_toBottomOf="@id/color_map_red_min" />
			<include android:id="@+id/color_map_green_max"
					 layout="@layout/numeric_input_3_digits"
					 android:layout_width="wrap_content"
					 android:layout_height="wrap_content"
					 android:layout_marginTop="4dp"
					 android:layout_marginEnd="16dp"
					 app:layout_constraintEnd_toEndOf="parent"
					 app:layout_constraintTop_toBottomOf="@id/color_map_red_max" />
			<include android:id="@+id/color_map_blue_min"
					 layout="@layout/numeric_input_3_digits"
					 android:layout_width="wrap_content"
					 android:layout_height="wrap_content"
					 android:layout_marginTop="4dp"
					 app:layout_constraintEnd_toStartOf="@id/color_map_blue_max"
					 app:layout_constraintStart_toEndOf="@id/color_map_labels_barrier"
					 app:layout_constraintTop_toBottomOf="@id/color_map_green_min" />
			<include android:id="@+id/color_map_blue_max"
					 layout="@layout/numeric_input_3_digits"
					 android:layout_width="wrap_content"
					 android:layout_height="wrap_content"
					 android:layout_marginTop="4dp"
					 android:layout_marginEnd="16dp"
					 app:layout_constraintEnd_toEndOf="parent"
					 app:layout_constraintTop_toBottomOf="@id/color_map_green_max" />

			<Space android:layout_width="match_parent"
				   android:layout_height="16dp"
				   app:layout_constraintBottom_toBottomOf="parent"
				   app:layout_constraintTop_toBottomOf="@id/color_map_blue_max" />
		</androidx.constraintlayout.widget.ConstraintLayout>
	</androidx.core.widget.NestedScrollView>
</LinearLayout>